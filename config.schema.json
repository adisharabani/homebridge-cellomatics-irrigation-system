          "type": "object",
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "required": true
            },
            "expose": {
              "title": "Expose",
              "type": "boolean",
              "required": true
            }
          }
        }
      }
    }
  }
}
